{
  "name": "dojo-roleplay-server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node --watch index.js",
    "build": "esbuild index.js --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "prettier": "^3.6.2",
    "vitest": "^2.1.4"
  }
}
